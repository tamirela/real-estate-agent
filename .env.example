# ─────────────────────────────────────────────────────────
# DFW Deal Agent — Environment Variables
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# REQUIRED: Anthropic API key (for Claude AI deal analysis)
# Get it at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# REQUIRED: Gmail setup for email alerts
# 1. Use your Gmail address as the sender
# 2. Create a Gmail App Password (NOT your regular password):
#    Go to: Google Account → Security → 2-Step Verification → App Passwords
#    Create one named "DFW Deal Agent"
GMAIL_SENDER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# OPTIONAL: RentCast API (improves rental income estimates)
# Free tier: 50 requests/month | Paid: $35/month
# Get it at: https://rentcast.io/
RENTCAST_API_KEY=

# OPTIONAL: RapidAPI key (for additional Zillow data)
# Get it at: https://rapidapi.com/
RAPIDAPI_KEY=
